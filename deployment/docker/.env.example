# Copy to .env and set POSTGRES_PASSWORD (required). Used by deployment/docker/docker-compose.yml

# --- PostgreSQL ---
POSTGRES_IMAGE=postgres:15-alpine
POSTGRES_DB=wg_control_plane
POSTGRES_USER=wguser
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# --- Application image (build locally or pull from registry) ---
WG_CP_IMAGE=wg-control-plane:latest
WG_CP_HTTP_PORT=8080
WG_CP_WG_PORT=51820

# --- App DB connection (DB_* derived in compose from POSTGRES_* except host) ---
DB_PORT=5432

# --- Public URL (emails, links) ---
APP_BASE_URL=http://localhost:8080

# --- Optional mail ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=WireGuard Control Plane

# --- Optional internal API key ---
APP_INTERNAL_API_KEY=

# --- WireGuard config path inside container (must match volume target) ---
WIREGUARD_CONFIG_DIR=/etc/wireguard
