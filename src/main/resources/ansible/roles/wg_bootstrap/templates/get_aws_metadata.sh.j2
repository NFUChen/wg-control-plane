#!/bin/bash
set -euo pipefail

# Get AWS metadata using IMDSv2
echo "Getting AWS metadata..." >&2

# Get token
echo "Requesting IMDSv2 token..." >&2
TOKEN=$(curl -sX PUT "http://169.254.169.254/latest/api/token" \
  -H "X-aws-ec2-metadata-token-ttl-seconds: {{ wg_aws_token_ttl }}" \
  --max-time 5 || echo "")

if [[ -z "$TOKEN" ]]; then
    echo "Failed to get IMDSv2 token" >&2
    exit 1
fi

echo "Token received successfully" >&2

# Get basic metadata
echo "Getting instance ID..." >&2
INSTANCE_ID=$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" \
  http://169.254.169.254/latest/meta-data/instance-id --max-time 5)

echo "Getting private IP..." >&2
PRIVATE_IP=$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" \
  http://169.254.169.254/latest/meta-data/local-ipv4 --max-time 5)

echo "Getting region..." >&2
REGION=$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" \
  http://169.254.169.254/latest/meta-data/placement/region --max-time 5)

echo "Getting availability zone..." >&2
AZ=$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" \
  http://169.254.169.254/latest/meta-data/placement/availability-zone --max-time 5)

echo "Getting MAC address..." >&2
MAC=$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" \
  http://169.254.169.254/latest/meta-data/mac --max-time 5)

# Get ENI ID
echo "Getting ENI ID for MAC: $MAC..." >&2
ENI_ID=$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" \
  http://169.254.169.254/latest/meta-data/network/interfaces/macs/$MAC/interface-id --max-time 5)

# Get VPC ID (bonus)
echo "Getting VPC ID..." >&2
VPC_ID=$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" \
  http://169.254.169.254/latest/meta-data/network/interfaces/macs/$MAC/vpc-id --max-time 5)

echo "All metadata collected successfully" >&2

# Create JSON payload matching UpsertInstanceMetadataRequest structure
JSON_PAYLOAD=$(cat << EOF
{
  "hostId": "{{ wg_host_id }}",
  "instanceId": "$INSTANCE_ID",
  "privateIp": "$PRIVATE_IP",
  "region": "$REGION",
  "availabilityZone": "$AZ",
  "networkInterfaceId": "$ENI_ID",
  "vpcId": "$VPC_ID"
}
EOF
)

# Output JSON for Ansible to parse
echo "$JSON_PAYLOAD"